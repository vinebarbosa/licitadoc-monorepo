NODE_ENV=development
HOST=0.0.0.0
PORT=3333

DATABASE_URL=postgres://postgres:postgres@localhost:5432/licitadoc

BETTER_AUTH_SECRET=replace-with-a-random-32-byte-secret
BETTER_AUTH_URL=http://localhost:3333
CORS_ORIGIN=http://localhost:5173

INVITE_EMAIL_PROVIDER=stub
RESEND_API_KEY=
RESEND_FROM_EMAIL="Licitadoc <onboarding@resend.dev>"

# Use "stub" for local development without external API calls.
# Use "openai" when TEXT_GENERATION_API_KEY is configured.
# Use "ollama" for real local generation with a locally running Ollama service:
#   TEXT_GENERATION_PROVIDER=ollama
#   TEXT_GENERATION_MODEL=qwen3.6:35b
#   TEXT_GENERATION_BASE_URL=http://127.0.0.1:11434
TEXT_GENERATION_PROVIDER=stub
TEXT_GENERATION_MODEL=gpt-4.1-mini
TEXT_GENERATION_API_KEY=
TEXT_GENERATION_BASE_URL=
# Optional. Example: 2000000 = about 33 minutes.
TEXT_GENERATION_TIMEOUT_MS=2000000

STORAGE_PROVIDER=s3
STORAGE_S3_ENDPOINT=http://localhost:4566
STORAGE_S3_REGION=us-east-1
STORAGE_S3_BUCKET=licitadoc-expense-requests
STORAGE_S3_ACCESS_KEY_ID=test
STORAGE_S3_SECRET_ACCESS_KEY=test
STORAGE_S3_FORCE_PATH_STYLE=true
EXPENSE_REQUEST_PDF_MAX_BYTES=3145728
SUPPORT_IMAGE_MAX_BYTES=5242880

# Realtime support ticket messaging.
# Use "disabled" locally when you do not need external socket delivery.
# Use "ably" when ABLY_API_KEY is configured.
REALTIME_PROVIDER=disabled
ABLY_API_KEY=
REALTIME_TOKEN_TTL_MS=3600000
