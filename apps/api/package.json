{
  "name": "@licitadoc/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app/server.ts",
    "build": "tsc -p tsconfig.json",
    "generate:openapi": "node --import tsx src/app/export-openapi.ts",
    "generate:postman": "node --import tsx src/app/export-postman.ts",
    "generate:contracts": "pnpm generate:openapi && pnpm generate:postman",
    "admin:create": "node --import tsx src/scripts/create-admin.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "lint": "biome check src drizzle.config.ts",
    "test": "tsx --test src/**/*.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/sensible": "^6.0.3",
    "@fastify/swagger": "^9.6.1",
    "@fastify/swagger-ui": "^5.2.3",
    "better-auth": "^1.3.7",
    "dotenv": "^17.2.2",
    "drizzle-orm": "^0.44.5",
    "fastify": "^5.6.0",
    "fastify-plugin": "^5.1.0",
    "fastify-zod-openapi": "^5.6.1",
    "pg": "^8.16.3",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/pg": "^8.15.5",
    "drizzle-kit": "^0.31.4",
    "pino-pretty": "^13.1.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  }
}
